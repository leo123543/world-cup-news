<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1080">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    width: 1080px;
    height: 1920px;
    overflow: hidden;
    background: #0B0D12;
    font-family: 'Inter', sans-serif;
    color: #FFFFFF;
  }

  .canvas {
    width: 1080px;
    height: 1920px;
    padding: 56px 72px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  /* 背景网格 */
  .canvas::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(22, 93, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(22, 93, 255, 0.04) 1px, transparent 1px);
    background-size: 72px 72px;
    pointer-events: none;
  }

  /* 顶部蓝色光晕 */
  .canvas::after {
    content: '';
    position: absolute;
    top: -250px;
    right: -150px;
    width: 700px;
    height: 700px;
    background: radial-gradient(circle, rgba(22, 93, 255, 0.14) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ─── HEADER ─── */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .logo-wrap {
    display: flex;
    align-items: center;
    height: 34px;
  }

  .logo-wrap svg {
    height: 34px;
    width: auto;
    max-width: 200px;
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 600;
    color: #9AA3AF;
    letter-spacing: 0.08em;
  }

  .live-dot {
    width: 10px;
    height: 10px;
    background: #EA3943;
    border-radius: 50%;
  }

  /* 品牌蓝分割线 */
  .divider {
    height: 2px;
    background: linear-gradient(90deg, #165DFF 0%, #40B3FF 60%, transparent 100%);
    margin-bottom: 40px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  /* ─── RANK + SCORE ROW ─── */
  .rank-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .rank-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 700;
    color: #FFFFFF;
    background: #EA3943;
    padding: 8px 20px;
    border-radius: 999px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .viral-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 600;
    color: #EA3943;
    letter-spacing: 0.06em;
  }

  /* ─── EYEBROW ─── */
  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 600;
    color: #165DFF;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 20px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  /* ─── HEADLINE ─── */
  .headline {
    font-family: 'Inter', sans-serif;
    font-size: 128px;
    font-weight: 800;
    line-height: 1.05;
    color: #FFFFFF;
    letter-spacing: -0.03em;
    word-break: break-word;
    overflow-wrap: break-word;
    max-height: calc(3 * 1.05 * 128px);
    overflow: hidden;
    margin-bottom: 36px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  /* ─── TEAMS ─── */
  .teams {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 40px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    min-height: 40px;
  }

  .team-chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 15px;
    font-weight: 600;
    color: #16C784;
    background: rgba(22, 199, 132, 0.12);
    border: 1px solid rgba(22, 199, 132, 0.4);
    border-radius: 999px;
    padding: 7px 20px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  /* ─── AIME INSIGHT BOX ─── */
  .insight-box {
    background: linear-gradient(175deg, #07256D 0%, #021642 48%, #021437 100%);
    border: 1px solid rgba(22, 93, 255, 0.5);
    border-radius: 20px;
    padding: 44px 48px;
    margin-bottom: 36px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .insight-box::before {
    content: '';
    position: absolute;
    left: 0;
    top: 24px;
    bottom: 24px;
    width: 4px;
    background: linear-gradient(180deg, #165DFF, #40B3FF);
    border-radius: 999px;
  }

  .insight-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 700;
    color: #165DFF;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .insight-text {
    font-family: 'Inter', sans-serif;
    font-size: 38px;
    font-weight: 400;
    line-height: 1.5;
    color: #E8ECFF;
    font-style: italic;
  }

  .insight-text:empty::before {
    content: 'Multi-agent analysis in progress...';
    color: #4A5160;
    font-style: italic;
  }

  /* ─── FOOTER ─── */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    padding-top: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .source-chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 14px;
    font-weight: 600;
    color: #165DFF;
    background: rgba(22, 93, 255, 0.12);
    border: 1px solid rgba(22, 93, 255, 0.35);
    border-radius: 999px;
    padding: 6px 18px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pub-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    color: #4A5160;
    letter-spacing: 0.04em;
  }

  .footer-right {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: #4A5160;
    letter-spacing: 0.1em;
  }

  .footer-right span {
    color: #165DFF;
  }

  /* 四角定位符 */
  .corner {
    position: absolute;
    width: 24px;
    height: 24px;
    z-index: 2;
  }
  .corner-tl { top: 24px; left: 24px; border-top: 2px solid rgba(22,93,255,0.4); border-left: 2px solid rgba(22,93,255,0.4); }
  .corner-tr { top: 24px; right: 24px; border-top: 2px solid rgba(22,93,255,0.4); border-right: 2px solid rgba(22,93,255,0.4); }
  .corner-bl { bottom: 24px; left: 24px; border-bottom: 2px solid rgba(22,93,255,0.4); border-left: 2px solid rgba(22,93,255,0.4); }
  .corner-br { bottom: 24px; right: 24px; border-bottom: 2px solid rgba(22,93,255,0.4); border-right: 2px solid rgba(22,93,255,0.4); }
</style>
</head>
<body>
<div class="canvas">
  <div class="corner corner-tl"></div>
  <div class="corner corner-tr"></div>
  <div class="corner corner-bl"></div>
  <div class="corner corner-br"></div>

  <div class="header">
    <div class="logo-wrap">{{ logo_svg | safe }}</div>
    <div class="live-badge">
      <div class="live-dot"></div>
      LIVE · FIFA WC 2026
    </div>
  </div>

  <div class="divider"></div>

  <div class="rank-row">
    <div class="rank-badge">#{{ card_index }} TOP STORY</div>
    <div class="viral-score">VIRAL SCORE: {{ virality_score }}</div>
  </div>

  <div class="eyebrow">WORLD CUP BREAKING · {{ fetch_date_hkt }}</div>

  <h1 class="headline">{{ sm_headline }}</h1>

  <div class="teams">
    {% for team in teams %}
    <div class="team-chip">{{ team }}</div>
    {% endfor %}
  </div>

  <div class="insight-box">
    <div class="insight-label">[ Aime Multi-Agent Insight ]</div>
    <div class="insight-text">{{ insight }}</div>
  </div>

  <div class="footer">
    <div class="footer-left">
      <div class="source-chip">{{ source }}</div>
      <div class="pub-time">{{ pub_ago }}</div>
    </div>
    <div class="footer-right">ANALYZED BY <span>AIME</span></div>
  </div>
</div>
</body>
</html>
