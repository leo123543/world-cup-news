<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=1920">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet">
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    width: 1920px;
    height: 1080px;
    overflow: hidden;
    background: #0B0D12;
    font-family: 'Inter', sans-serif;
    color: #FFFFFF;
  }

  .canvas {
    width: 1920px;
    height: 1080px;
    padding: 48px 80px;
    display: flex;
    flex-direction: column;
    position: relative;
    overflow: hidden;
  }

  /* 背景网格 */
  .canvas::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(22, 93, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(22, 93, 255, 0.03) 1px, transparent 1px);
    background-size: 80px 80px;
    pointer-events: none;
  }

  /* 右侧光晕 */
  .canvas::after {
    content: '';
    position: absolute;
    top: -200px;
    right: -200px;
    width: 800px;
    height: 800px;
    background: radial-gradient(circle, rgba(22, 93, 255, 0.1) 0%, transparent 70%);
    pointer-events: none;
  }

  /* ─── HEADER ─── */
  .header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 16px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  .header-left {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .logo-wrap {
    display: flex;
    align-items: center;
    height: 28px;
  }

  .logo-wrap svg {
    height: 28px;
    width: auto;
    max-width: 160px;
  }

  .rank-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 700;
    color: #FFFFFF;
    background: #EA3943;
    padding: 6px 18px;
    border-radius: 999px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .viral-score {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: #EA3943;
    letter-spacing: 0.06em;
  }

  .live-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: #9AA3AF;
    letter-spacing: 0.08em;
  }

  .live-dot {
    width: 8px;
    height: 8px;
    background: #EA3943;
    border-radius: 50%;
  }

  /* 品牌蓝分割线 */
  .divider {
    height: 2px;
    background: linear-gradient(90deg, #165DFF 0%, #40B3FF 50%, transparent 100%);
    margin-bottom: 28px;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
  }

  /* ─── BODY (两栏) ─── */
  .body {
    display: flex;
    gap: 60px;
    flex: 1;
    overflow: hidden;
    position: relative;
    z-index: 1;
  }

  /* ─── LEFT COLUMN ─── */
  .col-left {
    flex: 0 0 960px;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .eyebrow {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: #165DFF;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 16px;
    flex-shrink: 0;
  }

  .headline {
    font-family: 'Inter', sans-serif;
    font-size: 80px;
    font-weight: 800;
    line-height: 1.05;
    color: #FFFFFF;
    letter-spacing: -0.03em;
    word-break: break-word;
    overflow-wrap: break-word;
    max-height: calc(4 * 1.05 * 80px);
    overflow: hidden;
    margin-bottom: 24px;
    flex-shrink: 0;
  }

  .teams {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-bottom: 0;
    flex-shrink: 0;
    flex: 1;
    align-content: flex-start;
  }

  .team-chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: #16C784;
    background: rgba(22, 199, 132, 0.12);
    border: 1px solid rgba(22, 199, 132, 0.4);
    border-radius: 999px;
    padding: 5px 16px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    height: fit-content;
  }

  /* ─── RIGHT COLUMN ─── */
  .col-right {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  /* ─── AIME INSIGHT BOX ─── */
  .insight-box {
    background: linear-gradient(175deg, #07256D 0%, #021642 48%, #021437 100%);
    border: 1px solid rgba(22, 93, 255, 0.5);
    border-radius: 16px;
    padding: 32px 36px;
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .insight-box::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20px;
    bottom: 20px;
    width: 3px;
    background: linear-gradient(180deg, #165DFF, #40B3FF);
    border-radius: 999px;
  }

  .insight-label {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 700;
    color: #165DFF;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 16px;
  }

  .insight-text {
    font-family: 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 400;
    line-height: 1.55;
    color: #E8ECFF;
    font-style: italic;
    max-height: calc(5 * 1.55 * 28px);
    overflow: hidden;
  }

  .insight-text:empty::before {
    content: 'Multi-agent analysis in progress...';
    color: #4A5160;
    font-style: italic;
  }

  /* ─── FOOTER (全宽) ─── */
  .footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-shrink: 0;
    position: relative;
    z-index: 1;
    padding-top: 16px;
    margin-top: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .footer-left {
    display: flex;
    align-items: center;
    gap: 14px;
  }

  .source-chip {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: #165DFF;
    background: rgba(22, 93, 255, 0.12);
    border: 1px solid rgba(22, 93, 255, 0.35);
    border-radius: 999px;
    padding: 4px 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .pub-time {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    color: #4A5160;
    letter-spacing: 0.04em;
  }

  .footer-right {
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    font-weight: 600;
    color: #4A5160;
    letter-spacing: 0.1em;
  }

  .footer-right span {
    color: #165DFF;
  }

  /* 四角定位符 */
  .corner {
    position: absolute;
    width: 20px;
    height: 20px;
    z-index: 2;
  }
  .corner-tl { top: 20px; left: 20px; border-top: 2px solid rgba(22,93,255,0.35); border-left: 2px solid rgba(22,93,255,0.35); }
  .corner-tr { top: 20px; right: 20px; border-top: 2px solid rgba(22,93,255,0.35); border-right: 2px solid rgba(22,93,255,0.35); }
  .corner-bl { bottom: 20px; left: 20px; border-bottom: 2px solid rgba(22,93,255,0.35); border-left: 2px solid rgba(22,93,255,0.35); }
  .corner-br { bottom: 20px; right: 20px; border-bottom: 2px solid rgba(22,93,255,0.35); border-right: 2px solid rgba(22,93,255,0.35); }
</style>
</head>
<body>
<div class="canvas">
  <div class="corner corner-tl"></div>
  <div class="corner corner-tr"></div>
  <div class="corner corner-bl"></div>
  <div class="corner corner-br"></div>

