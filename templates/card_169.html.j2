          </g>
        </svg>
      </div>
      <div class="rank-badge">#{{ card_index }} Top Story</div>
    </div>
    <div class="header-right">
      <div class="viral-score">VIRAL {{ virality_score }}</div>
      <div class="live-badge">
        <div class="live-dot"></div>
        LIVE · FIFA WC 2026
      </div>
    </div>
  </div>

  <div class="rule"></div>

  <!-- BODY: two columns -->
  <div class="body">
    <!-- LEFT: rank + headline + teams -->
    <div class="col-left">
      <div class="eyebrow">BREAKING · {{ fetch_date_hkt }}</div>
      <h1 class="headline">{{ sm_headline }}</h1>
      <div class="teams">
        {% for team in teams %}
        <div class="team-chip">{{ team }}</div>
        {% endfor %}
      </div>
    </div>

    <!-- RIGHT: Aime analysis -->
    <div class="col-right">
      <div class="insight-head">
        <div class="insight-pip"></div>
        <div class="insight-label">Aime Analysis</div>
        <div class="insight-rule-line"></div>
        <div class="pub-time">{{ pub_ago }}</div>
      </div>
      <div class="insight-text">{{ insight }}</div>
    </div>
  </div>

  <!-- FOOTER -->
  <div class="footer">
    <div class="footer-left">
      <div class="source-tag">{{ source }}</div>
      <div class="pub-time">{{ fetch_date_hkt }}</div>
    </div>
    <div class="footer-right">ANALYZED BY <span>AIME</span></div>
  </div>
</div>
</body>
</html>
